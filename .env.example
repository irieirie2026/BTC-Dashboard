# Copy to .env.local and fill values. Never commit secrets.

# xAI / SpaceXAI (OpenAI-compatible) — Super Summary LLM prose + Knowledge Graph
XAI_API_KEY=
# Optional overrides:
# XAI_BASE_URL=https://api.x.ai/v1
# xAI model ids: grok-4.5 | grok-4.5-latest | grok-4.3 | grok-3-mini | …
# SS_LLM_MODEL=grok-4.5
# KG_LLM_MODEL=grok-4.5
# SS_CACHE_TTL=7200
# SS_COST_IN_PER_M=2.5
# SS_COST_OUT_PER_M=10

# Super Summary paywall (1 USDT or 1 USDC) — fill addresses when ready
# SS_PAYWALL_ENABLED=1
# SS_PAY_AMOUNT=1
# SS_PAY_ACCESS_DAYS=30
#
# SS_PAYWALL_SECRET = private signing key for unlock tokens (NOT a wallet address).
# After someone pays, the server gives the browser a signed "access ticket".
# This secret is what signs/verifies that ticket so users cannot forge unlocks.
# Use a long random string, e.g. openssl rand -hex 32
# Never share it publicly. If leaked, change it (all existing unlocks become invalid).
# SS_PAYWALL_SECRET=change-me-long-random
#
# Optional local test unlock (leave empty in production):
# Local/testing unlock code shown under “Developer unlock” on Home (not the HMAC secret)
# SS_PAYWALL_DEV_CODE=local-dev
# Receiving wallets (leave blank until configured):
# SS_PAY_USDT_ERC20=
# SS_PAY_USDC_ERC20=
# SS_PAY_USDT_TRC20=
# SS_PAY_USDC_SOLANA=

# Optional free-tier extras for Indicators prefetch
# SANTIMENT_API_KEY=
# DUNE_API_KEY=
# BTC_DUNE_QUERY_IDS=
